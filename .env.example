# API Keys
SERPAPI_API_KEY=your_serpapi_api_key_here

# Choose ONE of the following for AI validation:
# Option 1: Use OpenRouter (requires OpenRouter API key)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Option 2: Use OpenAI (requires OpenAI API key)
OPENAI_API_KEY=sk-your_openai_key_here

# Google Gemini API key (if using gemini as AI_MODEL)
GEMINI_API_KEY=your_gemini_api_key_here

# LinkedIn Settings (Optional - only needed if scraping required)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Search Settings
COLLEGE_NAME=Your College Name
BATCH_YEAR=2020
SEARCH_PAGES=5
SCRAPE_LIMIT=10

# Rate Limiting
REQUEST_DELAY=2
MAX_RETRIES=3

# AI Model Settings
AI_MODEL=openai  # Choose: 'openai' or 'gemini'
OPENAI_MODEL=gpt-4o-mini  # Model name for OpenAI/OpenRouter
GEMINI_MODEL=gemini-1.5-flash  # Model name for Gemini
